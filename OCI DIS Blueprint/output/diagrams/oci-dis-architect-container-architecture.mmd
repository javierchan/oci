flowchart TB
    User(["ARCHITECT · ANALYST · ADMIN"])

    subgraph WEB["WEB CONTAINER · Next.js 15 · Node.js 26"]
        direction LR
        UI1["Projects<br/>Dashboard"]
        UI2["Import · Capture<br/>Catalog"]
        UI3["Topology Map<br/>Integration Canvas"]
        UI4["BOM · Cost<br/>Monthly Rollout"]
        UI5["Library · Pricing<br/>Agent Operations"]
        UI6["Contextual<br/>App Assistant"]
    end

    subgraph API["API CONTAINER · FastAPI · Python 3.12"]
        direction LR
        REST["REST API v1<br/>OpenAPI · RBAC"]
        D1["Catalog · Governance<br/>Dashboard · Graph"]
        D2["Pricing · BOM<br/>Exports · Storage"]
        D3["AI Review · Support<br/>Agent Orchestration"]
        CALC["CALC ENGINE<br/>Import · QA · Volumetry"]
        PRICE["PRICING ENGINE<br/>Decimal · SKU · Tiers"]
        RULES["SERVICE RULES<br/>Limits · Interoperability"]
    end

    subgraph RUNTIME["PRODUCTION RUNTIME"]
        direction LR

        subgraph ASYNC["ASYNCHRONOUS CONTAINERS"]
            direction TB
            Worker["WORKER<br/>Import · Recalculate<br/>Pricing · BOM · Verify"]
            AgentWorker["AGENT-WORKER<br/>Isolated agents queue<br/>Function Calling"]
            Beat["BEAT<br/>Scheduled verification"]
        end

        subgraph DATA["PERSISTENCE CONTAINERS"]
            direction TB
            DB[("POSTGRESQL 16<br/>Governed data · Audit<br/>Snapshots · Agent runs")]
            Redis[("REDIS 7<br/>Broker · Results<br/>Provider telemetry")]
            MinIO[("MINIO<br/>Imports · Exports<br/>Rate cards · Reports")]
        end

        subgraph OCI["GOVERNED OCI SERVICES"]
            direction TB
            GenAI["OCI GENERATIVE AI<br/>Responses-first<br/>Advisory synthesis"]
            Guardrails["OCI GUARDRAILS<br/>Injection · PII · Safety"]
            Sources["OFFICIAL SOURCES<br/>Pricing · Limits<br/>Product evidence"]
            ObjectStorage["OCI OBJECT STORAGE<br/>Deployment artifact store"]
        end
    end

    User --> WEB
    WEB -->|"HTTPS · typed contracts"| REST

    REST --> D1
    REST --> D2
    REST --> D3
    D1 --> CALC
    D1 --> RULES
    D2 --> PRICE
    D2 --> RULES

    REST -->|"Long-running jobs"| Worker
    D3 -->|"AgentRun"| AgentWorker
    Beat --> Worker

    Worker -->|"Deterministic engines"| CALC
    Worker --> PRICE
    Worker --> RULES

    REST <--> DB
    Worker <--> Redis
    AgentWorker <--> Redis
    D2 <--> MinIO

    AgentWorker -->|"Redacted evidence"| GenAI
    AgentWorker --> Guardrails
    Worker --> Sources
    MinIO -. "Same S3 contract in OCI" .-> ObjectStorage

    DB -.- Truth["SYSTEM OF RECORD"]
    CALC -.- Authority["TECHNICAL AUTHORITY"]
    PRICE -.- CostAuthority["COMMERCIAL MATH AUTHORITY"]
    GenAI -.- Advisory["ADVISORY ONLY"]

