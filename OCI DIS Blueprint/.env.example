# ============================================================
# OCI DIS Blueprint — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# App
APP_NAME="OCI DIS Blueprint API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://dis:dis@db:5432/oci_dis

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redis
REDIS_URL=redis://redis:6379/0

# Object Storage — MinIO in dev (docker-compose), replace with OCI in prod
STORAGE_BUCKET=oci-dis-files
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio123

# Governed AI review — authentication is mounted from CODEX_HOME, never stored here
CODEX_BASE_URL=https://chatgpt.com/backend-api/codex
CODEX_MODEL=gpt-5.5
CODEX_WIRE_API=responses
CODEX_CONFIG_PATH=/codex/config.toml
CODEX_AUTH_JSON_PATH=/codex/auth.json

# Service Product verification schedule (disabled by default)
SERVICE_VERIFICATION_SCHEDULE_ENABLED=false
SERVICE_VERIFICATION_SCHEDULE_SECONDS=86400
SERVICE_VERIFICATION_STALE_SCAN_MAX_SOURCES=20

# Observability (optional)
OTLP_ENDPOINT=
LOG_LEVEL=INFO
