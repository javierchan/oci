# ============================================================
# OCI DIS Blueprint — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# App
APP_NAME="OCI DIS Blueprint API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://dis:dis@db:5432/oci_dis

# Redis
REDIS_URL=redis://redis:6379/0

# S3-compatible artifact storage. For OCI Object Storage, use the S3
# Compatibility API endpoint and a Customer Secret Key pair.
STORAGE_BUCKET=oci-dis-files
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-ashburn-1
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio123
STORAGE_ADDRESSING_STYLE=path

# Governed OCI Generative AI — the sk- secret is mounted from a file, never stored here
# Optional absolute override; defaults to $HOME/.oci-genai/api_key.
OCI_GENAI_API_KEY_FILE_HOST=
OCI_GENAI_REGION=us-chicago-1
OCI_GENAI_BASE_URL=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1
OCI_GENAI_MODEL_ID=openai.gpt-oss-20b
OCI_GENAI_MODEL_NAME="OpenAI gpt-oss-20b"
OCI_GENAI_SUPPORT_MODEL_ID=openai.gpt-oss-120b
OCI_GENAI_SUPPORT_MODEL_NAME="OpenAI gpt-oss-120b"
OCI_GENAI_KNOWLEDGE_MODEL_ID=openai.gpt-oss-120b
OCI_GENAI_KNOWLEDGE_MODEL_NAME="OpenAI gpt-oss-120b"
OCI_GENAI_LARGE_READ_TIMEOUT_SECONDS=300
OCI_GENAI_LARGE_MAX_OUTPUT_TOKENS=3072
# Required by OCI OpenAI-compatible agents. This is a resource OCID, not a secret.
OCI_GENAI_PROJECT_ID=
OCI_GENAI_COMPARTMENT_ID=
OCI_GENAI_TRANSPORT_MODE=auto
OCI_GENAI_RESPONSES_UNAVAILABLE_TTL_SECONDS=3600
OCI_GENAI_MAX_RETRIES=2
OCI_GENAI_RETRY_BASE_SECONDS=0.5
OCI_GENAI_RETRY_MAX_SECONDS=8.0
OCI_GENAI_GUARDRAILS_ENABLED=true
OCI_GENAI_GUARDRAILS_VERSION=1.0.1
OCI_GENAI_GUARDRAILS_FAILURE_MODE=closed
OCI_GENAI_METRICS_REDIS_ENABLED=true
OCI_GENAI_METRICS_REDIS_KEY=oci_dis:genai:metrics:v1
OCI_GENAI_METRICS_RETENTION_SECONDS=2592000
OCI_GENAI_AGENT_MAX_STEPS=4
OCI_GENAI_AGENT_MAX_EVIDENCE_CHARS=60000

# Service Product verification schedule (disabled by default)
SERVICE_VERIFICATION_SCHEDULE_ENABLED=true
SERVICE_VERIFICATION_SCHEDULE_SECONDS=86400
SERVICE_VERIFICATION_STALE_SCAN_MAX_SOURCES=20
OCI_GOVERNANCE_SCHEDULE_ENABLED=true
OCI_GOVERNANCE_SCHEDULE_SECONDS=86400
OCI_GOVERNANCE_LOCK_TTL_SECONDS=3600
OCI_GOVERNANCE_MAX_SOURCE_AGE_HOURS=72
OCI_GOVERNANCE_CURRENCY=USD

# Logging
LOG_LEVEL=INFO
